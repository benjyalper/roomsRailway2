<!DOCTYPE html>
<html lang="he-IL" dir="rtl">

    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>סידור חדרים</title>

        <!-- PWA / home-screen icon -->
        <link rel="manifest" href="/manifest.json" />
        <link rel="apple-touch-icon" href="/images/newRoom.png" />
        <meta name="apple-mobile-web-app-title" content="חדרים" />
        <meta name="theme-color" content="#018594" />

        <!-- Preload room image so it's ready before JS builds the grid -->
        <link rel="preload" as="image" href="/images/newRoom.png" />

        <link rel="stylesheet" href="/style.css">
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">
    </head>

    <body class="home-page">
        <!-- fixed navbar -->
        <%- include('partials/navbar') %>

        <!-- sticky sub-header: clinic name + decorative banner -->
        <div id="home-subheader">
            <div class="clinic-name"><%= clinicName %></div>
            <div class="page-banner"></div>
        </div>

        <!-- scrollable room grid — sized to whole rows by JS -->
        <div id="grid-scroll-wrapper">
            <div id="room-grid"></div>
        </div>

        <script>
            window.ROOMS = <%- JSON.stringify(rooms) %>;
            console.log("⚙️ window.ROOMS =", window.ROOMS);
        </script>

        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.0/jquery.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
        <script src="/script.js"></script>
    </body>

</html>
