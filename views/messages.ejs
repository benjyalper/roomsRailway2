<%- include('partials/head', { title: 'הודעות' }) %>

        <!-- fixed navbar -->
        <%- include('partials/navbar') %>

        <!-- clinic name in the white strip between navbar and banner -->
        <% if (typeof clinicName !== 'undefined' && clinicName) { %>
        <div class="clinic-name"><%= clinicName %></div>
        <% } %>

        <!-- decorative "sea-tone" banner -->
        <div class="page-banner"></div>

        <div class="container mt-3 pt-3">
            <!-- message input -->
            <div class="mb-4">
                <input type="text" id="input" class="form-control mb-2" placeholder="כתוב/כתבי הודעה..." />
                <button class="btn btn-primary w-100" onclick="submitMessage()">
                    שלח/י
                </button>
            </div>

            <!-- injected messages -->
            <div class="to-do-items list-group animate__animated" id="messageList"></div>
        </div>

        <!-- scripts -->
        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.0/jquery.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="/script.js"></script>
    </body>

</html>
