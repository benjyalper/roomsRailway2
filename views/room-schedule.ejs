<!DOCTYPE html>
<html lang="he" dir="rtl">

    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <!-- head partial will inject the <title> -->
        <%- include('partials/head', { title: 'טבלת חדרים' }) %>
        <link rel="stylesheet" href="/style.css" />
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    </head>

    <body>
        <!-- fixed navbar with page title -->
        <%- include('partials/navbar') %>

        <!-- decorative “sea-tone” banner -->
        <div class="page-banner"></div>

        <div class="container mt-3 pt-3 text-center">
            <!-- date selector -->
            <div class="mb-2">
                <input type="date" id="lookupDate" class="form-control" />
            </div>
            <!-- Hebrew day name -->
            <div id="hebrewDayName" style="font-size:1.5rem; font-weight:700; letter-spacing:0.05em; color:#1a6b74;"></div>
        </div>

        <div class="schedule-wrapper">
            <table id="scheduleTable">
                <thead>
                    <tr>
                        <th class="time-col"></th>
                        <% rooms.forEach(label => { %>
                        <th class="room-col"><%= label %></th>
                        <% }) %>
                    </tr>
                </thead>
                <tbody>
                    <% TIMES.forEach(time => { %>
                    <tr>
                        <th class="time-col"><%= time %></th>
                        <% rooms.forEach(label => { %>
                        <td class="grid-cell" data-room-hour="<%= label %> <%= time %>:00"></td>
                        <% }) %>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>

        <!-- scripts -->
        <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.7.0/jquery.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
        <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.1/moment.min.js"></script>
        <script src="/script.js"></script>
        <script>
            const HEB_DAYS = ["יום א'", "יום ב'", "יום ג'", "יום ד'", "יום ה'", "יום ו'", "יום ש'"];
            function updateHebrewDay(dateStr) {
                const el = document.getElementById('hebrewDayName');
                if (!el) return;
                const d = dateStr ? new Date(dateStr + 'T00:00:00') : new Date();
                el.textContent = HEB_DAYS[d.getDay()];
            }
            // Update on date-picker change
            document.getElementById('lookupDate').addEventListener('change', function () {
                updateHebrewDay(this.value);
            });
            // Init after script.js sets today's date
            window.addEventListener('load', function () {
                updateHebrewDay(document.getElementById('lookupDate').value);
            });
        </script>
    </body>

</html>