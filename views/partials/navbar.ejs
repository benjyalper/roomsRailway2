<!-- ── Import PDF Modal ─────────────────────────────────────────────────── -->
<div class="modal fade" id="importPdfModal" tabindex="-1" aria-labelledby="importPdfModalLabel" aria-hidden="true" dir="rtl">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="importPdfModalLabel">יבא קובץ סידור חדרים</h5>
        <button type="button" class="btn-close ms-0 me-auto" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body">
        <p class="text-muted small">
          ניתן להעלות PDF או Excel.<br>
          • PDF — תקבל קובץ Excel לבדיקה ועריכה לפני שמירה במערכת.<br>
          • Excel (.xlsx) — הנתונים ייכנסו ישירות למערכת.
        </p>
        <input type="file" class="form-control" id="pdfFileInput" accept=".pdf,.xlsx" />
        <div id="importPdfStatus" class="mt-3" style="display:none;"></div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">ביטול</button>
        <button type="button" class="btn btn-primary" id="importPdfBtn">יבא</button>
      </div>
    </div>
  </div>
</div>

<script>
(function () {
  const btn    = document.getElementById('importPdfBtn');
  const input  = document.getElementById('pdfFileInput');
  const status = document.getElementById('importPdfStatus');

  if (!btn) return;

  btn.addEventListener('click', async () => {
    const file = input.files[0];
    if (!file) {
      showStatus('danger', 'אנא בחר קובץ PDF או Excel תחילה.');
      return;
    }

    const name = file.name.toLowerCase();
    const isPdf   = name.endsWith('.pdf');
    const isExcel = name.endsWith('.xlsx');
    if (!isPdf && !isExcel) {
      showStatus('danger', 'סוג קובץ לא נתמך. השתמש ב-PDF או Excel (.xlsx).');
      return;
    }

    btn.disabled = true;
    btn.textContent = 'מעבד...';

    const form = new FormData();

    try {
      if (isPdf) {
        showStatus('info', 'מנתח PDF ויוצר קובץ Excel לבדיקה...');
        form.append('pdfFile', file);
        const resp = await fetch('/import-pdf', { method: 'POST', body: form });
        if (!resp.ok) {
          const data = await resp.json().catch(() => ({}));
          throw new Error(data.error || `HTTP ${resp.status}`);
        }
        // Download the returned Excel file
        const blob = await resp.blob();
        const url  = URL.createObjectURL(blob);
        const a    = document.createElement('a');
        a.href = url;
        a.download = `schedule-review-${Date.now()}.xlsx`;
        document.body.appendChild(a);
        a.click();
        a.remove();
        URL.revokeObjectURL(url);
        showStatus('success', '✅ קובץ Excel ירד למחשב. פתח אותו לבדיקה ועריכה, ואז העלה אותו שוב כאן (קובץ .xlsx) כדי לשמור במערכת.');
        btn.disabled    = false;
        btn.textContent = 'יבא';
        input.value     = '';
      } else {
        showStatus('info', 'מכניס נתונים מקובץ Excel למערכת...');
        form.append('xlsxFile', file);
        const resp = await fetch('/import-excel', { method: 'POST', body: form });
        const data = await resp.json();
        if (resp.ok && data.success) {
          showStatus('success', `✅ יובאו ${data.inserted} רשומות בהצלחה!`);
          btn.textContent = 'הושלם';
        } else {
          throw new Error(data.error || 'לא ידוע');
        }
      }
    } catch (err) {
      showStatus('danger', `שגיאה: ${err.message}`);
      btn.disabled    = false;
      btn.textContent = 'יבא';
    }
  });

  // Reset modal state when closed
  document.getElementById('importPdfModal').addEventListener('hidden.bs.modal', () => {
    input.value         = '';
    status.style.display = 'none';
    btn.disabled        = false;
    btn.textContent     = 'יבא';
  });

  function showStatus(type, msg) {
    status.style.display = 'block';
    status.className     = `alert alert-${type}`;
    status.textContent   = msg;
  }
})();

// ── Erase all data (admin) ──────────────────────────────────────────────
(function () {
  const link = document.getElementById('nav-erase-all');
  if (!link) return;
  link.addEventListener('click', async (e) => {
    e.preventDefault();
    if (!window.Swal) {
      if (!confirm('האם אתה בטוח שאתה רוצה למחוק את כל הנתונים?')) return;
      return doErase();
    }
    const result = await Swal.fire({
      title: 'האם אתה בטוח שאתה רוצה למחוק את כל הנתונים?',
      text: 'פעולה זו תמחק את כל הזמנות החדרים ולא ניתנת לביטול.',
      icon: 'warning',
      showCancelButton: true,
      confirmButtonText: 'כן, מחק הכל',
      cancelButtonText: 'ביטול',
      confirmButtonColor: '#dc3545'
    });
    if (result.isConfirmed) doErase();
  });

  async function doErase() {
    try {
      const resp = await fetch('/erase-all', { method: 'POST' });
      const data = await resp.json();
      if (resp.ok && data.success) {
        if (window.Swal) {
          Swal.fire({ icon: 'success', title: `נמחקו ${data.deleted} רשומות`, timer: 1800, showConfirmButton: false });
        } else {
          alert(`נמחקו ${data.deleted} רשומות`);
        }
        setTimeout(() => location.reload(), 1500);
      } else {
        const msg = `שגיאה: ${data.error || 'לא ידוע'}`;
        window.Swal ? Swal.fire({ icon: 'error', title: msg }) : alert(msg);
      }
    } catch (err) {
      const msg = `שגיאת רשת: ${err.message}`;
      window.Swal ? Swal.fire({ icon: 'error', title: msg }) : alert(msg);
    }
  }
})();
</script>